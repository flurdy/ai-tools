#!/usr/bin/env bash
# pl-mkworktree <branch>: create (or reuse) a worktree for <branch> under the
# worktrees parent dir, mirror useful local project files from the main checkout,
# and print the worktree path on stdout.
# Diagnostics go to stderr so the caller can capture the path cleanly.
set -uo pipefail

branch="${1:-}"
[ -z "$branch" ] && { echo "pl-mkworktree: branch required" >&2; exit 1; }

MAIN=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
MAIN=${MAIN%/.git}
[ -z "$MAIN" ] && { echo "pl-mkworktree: not in a git repo" >&2; exit 1; }

# worktrees parent: alongside an existing */worktrees/* entry, else a default
parent=""
while read -r p; do
  case "$p" in */worktrees/*) parent="${p%/worktrees/*}/worktrees"; break ;; esac
done < <(git -C "$MAIN" worktree list --porcelain | awk '/^worktree /{print $2}')
[ -z "$parent" ] && parent="$(dirname "$MAIN")/worktrees"
mkdir -p "$parent"

slug=$(printf '%s' "$branch" | tr '/' '-' | tr -cs 'A-Za-z0-9._-' '-')
dest="$parent/$slug"

if git -C "$MAIN" worktree list --porcelain | grep -qx "worktree $dest"; then
  echo "pl-mkworktree: reusing existing worktree $dest" >&2
  echo "$dest"; exit 0
fi

if git -C "$MAIN" show-ref --verify --quiet "refs/heads/$branch"; then
  # existing branch: attach as-is, never reset (preserve its commits)
  git -C "$MAIN" worktree add "$dest" "$branch" >&2
else
  # new branch: base on a freshly-fetched origin/main, not stale local main;
  # fall back to local HEAD if origin/main can't be resolved (offline / no remote)
  git -C "$MAIN" fetch --quiet origin main 2>/dev/null || true
  base=origin/main
  git -C "$MAIN" rev-parse --verify --quiet "$base" >/dev/null 2>&1 || base=HEAD
  git -C "$MAIN" worktree add "$dest" -b "$branch" "$base" >&2
fi

# mirror node_modules symlinks: root + each top-level package
link_one() {
  local src="$1" rel="$2"
  [ -e "$src" ] || return 0
  [ -e "$dest/$rel" ] && return 0
  mkdir -p "$(dirname "$dest/$rel")"
  ln -s "$src" "$dest/$rel"
}
link_one "$MAIN/node_modules" "node_modules"
for d in "$MAIN"/packages/*/; do
  pkg=$(basename "$d")
  link_one "$MAIN/packages/$pkg/node_modules" "packages/$pkg/node_modules"
done

# carry over untracked Pi project settings when present.
for rel in .pi/settings.json .pi/settings.local.json; do
  if [ -f "$MAIN/$rel" ] && [ ! -e "$dest/$rel" ]; then
    mkdir -p "$(dirname "$dest/$rel")"
    cp "$MAIN/$rel" "$dest/$rel"
  fi
done

echo "$dest"
